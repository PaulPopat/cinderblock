{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake Build",
			"type": "shell",
			"command": "cmake . -B ./.dist && cmake --build ./.dist",
			"group": "build"
		},
		{
			"label": "Debug Run",
			"type": "shell",
			"command": "./.dist/cinderblock",
			"group": "build",
			"dependsOn": "CMake Build"
		}
	]
}