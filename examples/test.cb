let namespace:segment:start 10i;


let namespace:segment:end 20i;

let app:main (command: string)
  use namespace

  struct TestStruct (
    first: int32,
    second: string
  )

  let test_func (subject: TestStruct, thing: float, second: int32): int32
    subject.second == "add"
      ? subject.first + second
      : subject.first - second;

  let start segment:start, command;

  let curried segment:end <- test_func;

  start -> curried;


"add" -> app:main;