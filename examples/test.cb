let namespace:segment:start 10;


let namespace:segment:end 20;

let app:main (string command)
  use namespace;

  struct TestStruct
    int first
    string second;

  let test_func (TestStruct subject, float thing, int second): int
    subject.second == "add"
      ? subject.first + second
      : subject.first - second;

  let start segment:start, command;

  let curried segment:end <- test_func;

  start -> curried;

let app:switch (instruction: string | int)
  let handle_string (string value) value;
  let handle_int (int _) "This is an int";

  instruction, handle_string, handle_int -> case;